# ─── Benchmark ────────────────────────────────────────────────────────────────

# round identifier — used to tag batch_metrics records
ROUND_ID=R1

# sensor load: SENSOR_COUNT sensors per container, SENSOR_NUMBER containers
SENSOR_COUNT=10
SENSOR_NUMBER=1
FREQUENCY_HZ=20

# edge computing: false = raw readings (R1–R4), true = pre-aggregated on sensor (R5)
EDGE_COMPUTING=false

# fault injection: randomly drops or corrupts Kafka messages
FAULT_INJECTION=false
FAULT_INJECTION_PROBABILITY=0.1

# spark resources
SPARK_MASTER_CPUS=2
CHECKPOINT_DIR=/checkpoint

# micro-batch interval: how often Spark triggers a processing cycle
TRIGGER_INTERVAL=5 seconds

# checkpoint interval: how often Spark persists streaming state
CHECKPOINT_INTERVAL=30 seconds

# aggregation window: time range each micro-batch aggregates over
WINDOW_DURATION=1 seconds

# watermark: max tolerated delay for late-arriving events (must be >= WINDOW_DURATION)
WATERMARK=5 seconds


# ─── Visualization and testing of architecture ─────────────────────────────────────

# monitored area displayed on the frontend map
AREA_LAT=-22.00712784767658
AREA_LON=-47.895427018512386
AREA_NAME=ICMC USP São Carlos
AREA_URL=http://www.icmc.usp.br/imprensa/5321/_thumb1/icmc-destaque.png

# seed bot credentials (created automatically on first startup to register sensors via API)
API_USERNAME=soundmap
API_EMAIL=soundmap@soundmap.internal
API_PASSWORD=papagaio_brabo_123
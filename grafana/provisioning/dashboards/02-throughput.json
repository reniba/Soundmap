{
  "uid": "throughput",
  "title": "Throughput do Pipeline",
  "description": "Taxa de ingestão e processamento de eventos no pipeline Spark Structured Streaming",
  "tags": ["soundmap", "throughput"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Avg Input rows/s",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT avg(input_rows_per_sec) AS \"Input rows/s\" FROM batch_metrics WHERE $__timeFilter(batch_timestamp) AND input_rows_per_sec > 0",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Avg Processed rows/s",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT avg(proc_rows_per_sec) AS \"Processed rows/s\" FROM batch_metrics WHERE $__timeFilter(batch_timestamp) AND proc_rows_per_sec > 0",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Total de Batches (janela atual)",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS \"Batches\" FROM batch_metrics WHERE $__timeFilter(batch_timestamp)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "text", "value": null } ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Total de Eventos Processados",
      "type": "stat",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(input_rows) AS \"Eventos\" FROM batch_metrics WHERE $__timeFilter(batch_timestamp)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "text", "value": null } ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Input rows/s vs Processed rows/s",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(batch_timestamp, $__interval, NULL),\n  avg(input_rows_per_sec)  AS \"Input rows/s\",\n  avg(proc_rows_per_sec)   AS \"Processed rows/s\"\nFROM batch_metrics\nWHERE $__timeFilter(batch_timestamp)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Eventos por Batch (input_rows)",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(batch_timestamp, $__interval, NULL),\n  sum(input_rows) AS \"Eventos por batch\"\nFROM batch_metrics\nWHERE $__timeFilter(batch_timestamp)\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Eventos Esperados vs Recuperados",
      "description": "Detecta perda de eventos. Em condições normais as curvas devem ser idênticas.",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "noisedb" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "noisedb" },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(batch_timestamp, $__interval, NULL),\n  avg(events_expected)  AS \"Esperados\",\n  avg(events_recovered) AS \"Recuperados\"\nFROM batch_metrics\nWHERE $__timeFilter(batch_timestamp)\n  AND events_expected IS NOT NULL\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Esperados" }, "properties": [ { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } } ] },
          { "matcher": { "id": "byName", "options": "Recuperados" }, "properties": [ { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } } ] }
        ]
      }
    }
  ]
}
